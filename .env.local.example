# Supabase connection
# For server-side actions that do many DB queries (server actions, API routes),
# Supabase auto-uses Transaction mode via PgBouncer at port 6543.
# The @supabase/supabase-js client uses the REST API (PostgREST) which
# is internally pooled, so no manual config needed for our usage.
# Only direct postgres:// connection strings (e.g. Prisma, raw pg) need
# ?pgbouncer=true&connection_limit=1 — we don't use those.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Tap Payments (Kuwait)
TAP_SECRET_KEY=
TAP_PUBLIC_KEY=

# Resend (transactional email)
RESEND_API_KEY=

# Sentry error monitoring (https://sentry.io)
NEXT_PUBLIC_SENTRY_DSN=

# Upstash Redis for rate limiting (https://upstash.com)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_CLARITY_ID=
